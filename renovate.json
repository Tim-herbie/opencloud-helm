{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts\\/opencloud\\/values\\.yaml$/"
      ],
      "matchStrings": [
        "\\s{4}[a-z]+:\\n\\s{6}enabled:\\s(?:true|false)\\n\\s{6}tag:\\s(?<currentValue>(?<compatibility>[a-z-]+-)\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "opencloudeu/web-extensions",
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^(?<compatibility>{{{compatibility}}})(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    }
  ]
}
